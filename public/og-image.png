/**
 * app/opengraph-image.tsx
 * Next.js 14 Metadata Route — auto-generates /og-image at runtime.
 * Served as the og:image for the homepage when shared on social media.
 *
 * Uses Next.js ImageResponse (Vercel/Edge-compatible, no sharp needed).
 * Output: 1200×630px PNG — the universal OG image standard.
 *
 * Individual pages can create their own opengraph-image.tsx to override this.
 * Example: app/programs/cna/opengraph-image.tsx for program-specific OG images.
 *
 * Docs: https://nextjs.org/docs/app/api-reference/file-conventions/metadata/opengraph-image
 *
 * Note for Cloudflare Pages:
 *   ImageResponse uses the Edge runtime. Cloudflare Pages supports Edge Functions.
 *   Ensure next.config.ts does NOT set output: 'export' (static export breaks this).
 *   If static export is required, replace this with a pre-generated PNG in /public/.
 */

import { ImageResponse } from "next/og";

/* ── Route segment config ────────────────────────────────────────────────── */
export const runtime = "edge";
export const alt = "Rhode Island Education Center for H.O.P.E. — Free Healthcare Training Programs";
export const size = { width: 1200, height: 630 };
export const contentType = "image/png";

/* ─── OG IMAGE ───────────────────────────────────────────────────────────── */
export default function Image() {
  return new ImageResponse(
    (
      <div
        style={{
          width: "1200px",
          height: "630px",
          display: "flex",
          flexDirection: "column",
          background: "linear-gradient(145deg, #08122E 0%, #0C1B4D 55%, #162260 100%)",
          position: "relative",
          overflow: "hidden",
          fontFamily: "Georgia, 'Times New Roman', serif",
        }}
      >

        {/* ── Background decorative stars ────────────────────────────────── */}
        {[
          { top: 40,  left: 60,  size: 10, opacity: 0.25 },
          { top: 80,  left: 180, size: 7,  opacity: 0.18 },
          { top: 30,  left: 320, size: 12, opacity: 0.2  },
          { top: 120, left: 90,  size: 8,  opacity: 0.15 },
          { top: 55,  left: 500, size: 9,  opacity: 0.22 },
          { top: 490, left: 900, size: 11, opacity: 0.2  },
          { top: 560, left: 1050,size: 8,  opacity: 0.15 },
          { top: 440, left: 1120,size: 14, opacity: 0.18 },
          { top: 510, left: 750, size: 9,  opacity: 0.2  },
          { top: 580, left: 200, size: 7,  opacity: 0.15 },
        ].map((s, i) => (
          <div
            key={i}
            style={{
              position: "absolute",
              top: s.top,
              left: s.left,
              width: s.size,
              height: s.size,
              background: "#C8A136",
              opacity: s.opacity,
              clipPath:
                "polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%)",
            }}
          />
        ))}

        {/* ── Large ghost anchor watermark ─────────────────────────────── */}
        <div
          style={{
            position: "absolute",
            right: -40,
            top: "50%",
            transform: "translateY(-50%)",
            width: 500,
            height: 600,
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            opacity: 0.05,
          }}
        >
          {/* Simplified anchor rendered with divs (SVG not fully supported in ImageResponse) */}
          <div style={{
            width: 8, height: 420, background: "#C8A136",
            position: "absolute", top: 90, left: "50%", marginLeft: -4,
            borderRadius: 4,
          }} />
          <div style={{
            width: 280, height: 8, background: "#C8A136",
            position: "absolute", top: 220, left: "50%", marginLeft: -140,
            borderRadius: 4,
          }} />
          <div style={{
            width: 100, height: 100, border: "8px solid #C8A136",
            borderRadius: "50%", position: "absolute", top: 10, left: "50%",
            marginLeft: -50,
          }} />
        </div>

        {/* ── Left accent bar ──────────────────────────────────────────── */}
        <div style={{
          position: "absolute",
          left: 0, top: 0, bottom: 0,
          width: 6,
          background: "linear-gradient(to bottom, #C8A136, rgba(200,161,54,0.1))",
        }} />

        {/* ── Top accent line ──────────────────────────────────────────── */}
        <div style={{
          position: "absolute",
          top: 0, left: 0, right: 0,
          height: 4,
          background: "linear-gradient(to right, #C8A136, #1B7A8C, #C8A136)",
        }} />

        {/* ── Main content ─────────────────────────────────────────────── */}
        <div style={{
          display: "flex",
          flexDirection: "column",
          justifyContent: "center",
          padding: "60px 80px",
          height: "100%",
          maxWidth: 760,
        }}>

          {/* Badge */}
          <div style={{
            display: "flex",
            alignItems: "center",
            gap: 10,
            marginBottom: 28,
          }}>
            <div style={{
              background: "rgba(200,161,54,0.15)",
              border: "1px solid rgba(200,161,54,0.4)",
              padding: "6px 16px",
              color: "#DEB840",
              fontSize: 13,
              letterSpacing: "0.15em",
              fontFamily: "Georgia, serif",
              fontWeight: 700,
            }}>
              501(c)(3) NONPROFIT · WARWICK, RHODE ISLAND
            </div>
          </div>

          {/* Main title */}
          <div style={{
            fontSize: 62,
            fontWeight: 900,
            color: "#FFFFFF",
            lineHeight: 1.05,
            marginBottom: 20,
            fontFamily: "Georgia, 'Times New Roman', serif",
            letterSpacing: "-0.01em",
          }}>
            <span style={{ display: "block" }}>Free Healthcare</span>
            <span style={{ display: "block", color: "#C8A136", fontStyle: "italic" }}>
              Training Programs
            </span>
            <span style={{ display: "block", fontSize: 52 }}>for Rhode Islanders.</span>
          </div>

          {/* Description */}
          <div style={{
            fontSize: 20,
            color: "rgba(255,255,255,0.65)",
            lineHeight: 1.55,
            marginBottom: 36,
            fontFamily: "Georgia, serif",
            fontWeight: 400,
            maxWidth: 620,
          }}>
            100% grant-funded CNA, EMT, Phlebotomy, EKG, and Patient Care Tech
            certification. Apply today at rieducationcenter.org
          </div>

          {/* Program pills */}
          <div style={{ display: "flex", gap: 12, flexWrap: "wrap" }}>
            {["CNA", "EMT-Basic", "Phlebotomy", "EKG", "PCT", "AEMT-Cardiac"].map((prog) => (
              <div
                key={prog}
                style={{
                  background: "rgba(255,255,255,0.08)",
                  border: "1px solid rgba(255,255,255,0.15)",
                  color: "rgba(255,255,255,0.75)",
                  padding: "8px 16px",
                  fontSize: 14,
                  fontWeight: 600,
                  letterSpacing: "0.06em",
                  fontFamily: "Georgia, serif",
                }}
              >
                {prog}
              </div>
            ))}
          </div>
        </div>

        {/* ── Right panel ──────────────────────────────────────────────── */}
        <div style={{
          position: "absolute",
          right: 80,
          top: "50%",
          transform: "translateY(-50%)",
          display: "flex",
          flexDirection: "column",
          alignItems: "center",
          gap: 24,
        }}>

          {/* Star ring decoration */}
          <div style={{
            width: 180,
            height: 180,
            borderRadius: "50%",
            border: "2px solid rgba(200,161,54,0.3)",
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            position: "relative",
          }}>
            {/* Inner ring */}
            <div style={{
              width: 140,
              height: 140,
              borderRadius: "50%",
              border: "1px solid rgba(200,161,54,0.15)",
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
            }}>
              <div style={{
                fontSize: 64,
                lineHeight: 1,
              }}>⚓</div>
            </div>
          </div>

          {/* Stats */}
          {[
            { num: "100%", label: "Grant-Funded" },
            { num: "8+",   label: "Programs" },
            { num: "RI",   label: "State Approved" },
          ].map((stat) => (
            <div key={stat.label} style={{
              textAlign: "center",
            }}>
              <div style={{
                fontSize: 32,
                fontWeight: 900,
                color: "#C8A136",
                lineHeight: 1,
                fontFamily: "Georgia, serif",
              }}>{stat.num}</div>
              <div style={{
                fontSize: 12,
                color: "rgba(255,255,255,0.45)",
                letterSpacing: "0.1em",
                marginTop: 2,
                fontFamily: "Georgia, serif",
              }}>{stat.label}</div>
            </div>
          ))}
        </div>

        {/* ── Bottom domain bar ─────────────────────────────────────────── */}
        <div style={{
          position: "absolute",
          bottom: 0,
          left: 0,
          right: 0,
          height: 52,
          background: "rgba(0,0,0,0.3)",
          borderTop: "1px solid rgba(200,161,54,0.2)",
          display: "flex",
          alignItems: "center",
          justifyContent: "space-between",
          padding: "0 80px",
        }}>
          <div style={{
            fontSize: 16,
            color: "#C8A136",
            letterSpacing: "0.08em",
            fontWeight: 700,
            fontFamily: "Georgia, serif",
          }}>
            rieducationcenter.org
          </div>
          <div style={{
            fontSize: 13,
            color: "rgba(255,255,255,0.35)",
            letterSpacing: "0.06em",
            fontFamily: "Georgia, serif",
          }}>
            Rhode Island Education Center for H.O.P.E. · EIN: 99-3099438
          </div>
        </div>

      </div>
    ),
    {
      ...size,
    }
  );
}